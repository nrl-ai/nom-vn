# ============================================================================
# nom-vn — example environment for local dev / testing
# ----------------------------------------------------------------------------
# Copy this file to `.env` and fill in the values. `.env` is gitignored, so
# secrets stay local. Anything left blank is simply not used by `nom serve`.
# ============================================================================

# ---- Cloud LLM adapters (used by tests + manual integration runs) ----------
# Get an OpenAI key at https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Optional: route OpenAI() at any OpenAI-compatible gateway by setting
# base_url= in code, OR by exporting OPENAI_BASE_URL and reading it yourself.
# Examples: https://api.deepseek.com/v1, https://openrouter.ai/api/v1, etc.

# Get an Anthropic key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ---- Ollama (local LLM) — defaults already work, override only if needed ---
# OLLAMA_BASE_URL=http://localhost:11434

# ---- OpenTelemetry (optional, for tracing) ---------------------------------
# Set any of these and `nom serve` will auto-install OTel instrumentation.
# OTEL_SERVICE_NAME=nom-chat
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_TRACES_EXPORTER=otlp

# ---- nom serve runtime overrides (optional) --------------------------------
# NOM_DATA_DIR=~/.nom              # default storage path
# NOM_DEFAULT_MODEL=qwen3:8b       # default Ollama model
